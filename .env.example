# App
PORT=3000
NODE_ENV=development

# Database (Prisma) — required for migrate, seed, and the API
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME?schema=public

# Neon (example): copy "Connection string" from the Neon dashboard.
# Use the *pooler* host for the running API; direct host is fine for migrate/seed.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h

# Redis (cache, Bull, throttler)
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS (required in production for browser clients on another origin)
# Comma-separated, no spaces — e.g. front-end Vercel URL + local dev
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
# CORS_CREDENTIALS=false
# CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS

# Optional: mail (see src/config/mail.config.ts)
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=

# Optional: Sentry
# SENTRY_DSN=
# SENTRY_DEBUG=false
# SENTRY_SAMPLE_RATE=1.0
# SENTRY_TRACES_SAMPLE_RATE=1.0

# Optional: seed (prisma/seed.ts)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME=
