# App
PORT=3000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h

# Redis (cache, Bull, throttler)
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:3000

# Optional: mail (see src/config/mail.config.ts)
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=

# Optional: Sentry
# SENTRY_DSN=
# SENTRY_DEBUG=false
# SENTRY_SAMPLE_RATE=1.0
# SENTRY_TRACES_SAMPLE_RATE=1.0

# Optional: seed (prisma/seed.ts)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME=
